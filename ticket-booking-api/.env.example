# Example environment file for local/dev.
# Copy to `.env` and adjust values.

APP_NAME=Event Ticket Booking API
API_V1_PREFIX=/api/v1
DEBUG=true

# Local Mongo (Docker) default
MONGODB_URI=mongodb://mongo:27017
MONGODB_DB=ticket_booking

# Redis (Docker) default
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
SEAT_LOCK_TTL_SECONDS=300

# JWT
JWT_SECRET_KEY=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
